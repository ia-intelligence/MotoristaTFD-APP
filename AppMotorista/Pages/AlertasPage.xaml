<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="AppMotorista.Pages.AlertasPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:models="clr-namespace:AppMotorista.Models"
    xmlns:pages="clr-namespace:AppMotorista.Pages"
    xmlns:viewmodels="clr-namespace:AppMotorista.ViewModels"
    x:DataType="viewmodels:AlertasViewModel"
    BackgroundColor="#ECECEC"
    Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto,*">

        <!-- TOPO -->
        <Grid
            Grid.Row="0"
            Padding="18,24,18,18"
            BackgroundColor="#2357C6"
            RowDefinitions="Auto,Auto"
            ColumnDefinitions="48,*,Auto">

            <ImageButton
                BackgroundColor="Transparent"
                Command="{Binding VoltarCommand}"
                HeightRequest="26"
                Source="arrow_left_icon.svg"
                WidthRequest="26" />

            <Label
                Grid.Column="1"
                FontAttributes="Bold"
                FontSize="24"
                HorizontalTextAlignment="Center"
                Text="{Binding TituloPagina}"
                TextColor="White"
                VerticalTextAlignment="Center" />

            <Button
                Grid.Column="2"
                BackgroundColor="White"
                Command="{Binding NovaOcorrenciaCommand}"
                CornerRadius="14"
                FontAttributes="Bold"
                FontSize="12"
                HeightRequest="38"
                Padding="12,6"
                Text="+ Ocorrência"
                TextColor="#2357C6" />

            <Label
                Grid.Row="1"
                Grid.ColumnSpan="3"
                Margin="0,14,0,0"
                FontSize="13"
                Text="{Binding Resumo}"
                TextColor="#DCE6FF" />
        </Grid>

        <!-- CONTEÚDO -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="18,18,18,24" Spacing="18">

                <!-- ALERTAS -->
                <VerticalStackLayout Spacing="12">
                    <Label
                        FontAttributes="Bold"
                        FontSize="18"
                        Text="Alertas ativos"
                        TextColor="#1B1B1B" />

                    <CollectionView
                        ItemsSource="{Binding AlertasAtivos}"
                        SelectionMode="None">
                        <CollectionView.ItemsLayout>
                            <LinearItemsLayout Orientation="Vertical" ItemSpacing="12" />
                        </CollectionView.ItemsLayout>

                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="models:AlertaItem">
                                <Border
                                    Padding="16"
                                    BackgroundColor="White"
                                    StrokeThickness="0"
                                    StrokeShape="RoundRectangle 20">

                                    <VerticalStackLayout Spacing="12">
                                        <Grid ColumnDefinitions="*,Auto">
                                            <VerticalStackLayout Spacing="4">
                                                <Label
                                                    FontAttributes="Bold"
                                                    FontSize="17"
                                                    Text="{Binding Titulo}"
                                                    TextColor="#1B1B1B" />
                                                <Label
                                                    FontSize="13"
                                                    Text="{Binding Descricao}"
                                                    TextColor="#666666" />
                                            </VerticalStackLayout>

                                            <Border
                                                Grid.Column="1"
                                                Padding="10,5"
                                                BackgroundColor="{Binding CorFundo}"
                                                StrokeThickness="0"
                                                StrokeShape="RoundRectangle 12"
                                                VerticalOptions="Start">
                                                <Label
                                                    FontAttributes="Bold"
                                                    FontSize="12"
                                                    Text="{Binding Severidade}"
                                                    TextColor="{Binding CorTexto}" />
                                            </Border>
                                        </Grid>

                                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                                            <VerticalStackLayout Spacing="2">
                                                <Label
                                                    FontSize="12"
                                                    Text="{Binding Origem}"
                                                    TextColor="#2357C6" />
                                                <Label
                                                    FontSize="12"
                                                    Text="{Binding DataHora}"
                                                    TextColor="#777777" />
                                            </VerticalStackLayout>

                                            <Button
                                                Grid.Column="1"
                                                BackgroundColor="#F3F5FB"
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type pages:AlertasPage}}, Path=BindingContext.AbrirItemCommand}"
                                                CommandParameter="{Binding .}"
                                                CornerRadius="14"
                                                HeightRequest="40"
                                                Text="Detalhes"
                                                TextColor="#2357C6" />
                                        </Grid>
                                    </VerticalStackLayout>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>

                <!-- OCORRÊNCIAS -->
                <VerticalStackLayout Spacing="12">
                    <Label
                        FontAttributes="Bold"
                        FontSize="18"
                        Text="Ocorrências recentes"
                        TextColor="#1B1B1B" />

                    <CollectionView
                        ItemsSource="{Binding OcorrenciasRecentes}"
                        SelectionMode="None">
                        <CollectionView.ItemsLayout>
                            <LinearItemsLayout Orientation="Vertical" ItemSpacing="12" />
                        </CollectionView.ItemsLayout>

                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="models:AlertaItem">
                                <Border
                                    Padding="16"
                                    BackgroundColor="White"
                                    StrokeThickness="0"
                                    StrokeShape="RoundRectangle 20">

                                    <VerticalStackLayout Spacing="12">
                                        <Grid ColumnDefinitions="*,Auto">
                                            <VerticalStackLayout Spacing="4">
                                                <Label
                                                    FontAttributes="Bold"
                                                    FontSize="17"
                                                    Text="{Binding Titulo}"
                                                    TextColor="#1B1B1B" />
                                                <Label
                                                    FontSize="13"
                                                    Text="{Binding Descricao}"
                                                    TextColor="#666666" />
                                            </VerticalStackLayout>

                                            <Border
                                                Grid.Column="1"
                                                Padding="10,5"
                                                BackgroundColor="{Binding CorFundo}"
                                                StrokeThickness="0"
                                                StrokeShape="RoundRectangle 12"
                                                VerticalOptions="Start">
                                                <Label
                                                    FontAttributes="Bold"
                                                    FontSize="12"
                                                    Text="{Binding Severidade}"
                                                    TextColor="{Binding CorTexto}" />
                                            </Border>
                                        </Grid>

                                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                                            <VerticalStackLayout Spacing="2">
                                                <Label
                                                    FontSize="12"
                                                    Text="{Binding Origem}"
                                                    TextColor="#2357C6" />
                                                <Label
                                                    FontSize="12"
                                                    Text="{Binding DataHora}"
                                                    TextColor="#777777" />
                                            </VerticalStackLayout>

                                            <Button
                                                Grid.Column="1"
                                                BackgroundColor="#F3F5FB"
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type pages:AlertasPage}}, Path=BindingContext.AbrirItemCommand}"
                                                CommandParameter="{Binding .}"
                                                CornerRadius="14"
                                                HeightRequest="40"
                                                Text="Detalhes"
                                                TextColor="#2357C6" />
                                        </Grid>
                                    </VerticalStackLayout>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>