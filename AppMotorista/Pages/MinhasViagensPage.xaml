<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="AppMotorista.Pages.MinhasViagensPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:models="clr-namespace:AppMotorista.Models"
    xmlns:viewmodels="clr-namespace:AppMotorista.ViewModels"
    x:DataType="viewmodels:MinhasViagensViewModel"
    BackgroundColor="#ECECEC"
    Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto,*">

        <!-- TOPO -->
        <Grid
            Grid.Row="0"
            Padding="18,24,18,18"
            BackgroundColor="#2357C6"
            RowDefinitions="Auto,Auto"
            ColumnDefinitions="48,*">

            <ImageButton
                BackgroundColor="Transparent"
                Command="{Binding VoltarCommand}"
                HeightRequest="26"
                Source="arrow_left_icon.svg"
                WidthRequest="26" />

            <Label
                Grid.Column="1"
                FontAttributes="Bold"
                FontSize="24"
                HorizontalTextAlignment="Center"
                Text="{Binding TituloPagina}"
                TextColor="White"
                VerticalTextAlignment="Center" />

            <Label
                Grid.Row="1"
                Grid.ColumnSpan="2"
                Margin="0,14,0,0"
                FontSize="13"
                Text="{Binding ResumoPagina}"
                TextColor="#DCE6FF" />
        </Grid>

        <!-- CONTEÚDO -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="18,18,18,24" Spacing="18">


                <VerticalStackLayout Spacing="12">
                    <Label
        FontAttributes="Bold"
        FontSize="18"
        Text="Em andamento"
        TextColor="#1B1B1B" />

                    <CollectionView
        ItemsSource="{Binding EmAndamento}"
        SelectionMode="None">
                        <CollectionView.ItemsLayout>
                            <LinearItemsLayout Orientation="Vertical" ItemSpacing="12" />
                        </CollectionView.ItemsLayout>

                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="models:ReceptionTripItem">
                                <Border
                    Padding="16"
                    BackgroundColor="White"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 20">

                                    <VerticalStackLayout Spacing="12">
                                        <Grid ColumnDefinitions="*,Auto">
                                            <VerticalStackLayout Spacing="2">
                                                <Label
                                    FontAttributes="Bold"
                                    FontSize="17"
                                    Text="{Binding Destino}"
                                    TextColor="#1B1B1B" />
                                                <Label
                                    FontSize="13"
                                    Text="{Binding Data}"
                                    TextColor="#777777" />
                                            </VerticalStackLayout>

                                            <Border
                                Grid.Column="1"
                                Padding="10,5"
                                BackgroundColor="#FFF4E5"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 12">
                                                <Label
                                    FontAttributes="Bold"
                                    FontSize="12"
                                    Text="{Binding Status}"
                                    TextColor="#B96A00" />
                                            </Border>
                                        </Grid>

                                        <Grid ColumnDefinitions="*,*">
                                            <VerticalStackLayout Spacing="4">
                                                <Label FontSize="12" Text="Horário" TextColor="#2357C6" />
                                                <Label FontSize="14" Text="{Binding Horario}" TextColor="#1B1B1B" />
                                            </VerticalStackLayout>

                                            <VerticalStackLayout Grid.Column="1" Spacing="4">
                                                <Label FontSize="12" Text="Veículo" TextColor="#2357C6" />
                                                <Label FontSize="14" Text="{Binding Veiculo}" TextColor="#1B1B1B" />
                                            </VerticalStackLayout>
                                        </Grid>

                                        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
                                            <Label
                                FontAttributes="Bold"
                                FontSize="12"
                                Text="●"
                                TextColor="#F29A2E"
                                VerticalTextAlignment="Center" />

                                            <Label
                                Grid.Column="1"
                                VerticalTextAlignment="Center"
                                FontSize="13"
                                Text="Viagem em execução"
                                TextColor="#666666" />

                                            <Button
                                Grid.Column="2"
                                BackgroundColor="#F3F5FB"
                                Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:MinhasViagensViewModel}}, Path=AbrirMapaCommand}"
                                CommandParameter="{Binding .}"
                                CornerRadius="14"
                                HeightRequest="40"
                                Text="Mapa"
                                TextColor="#2357C6" />
                                        </Grid>
                                    </VerticalStackLayout>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>


                <!-- CONFIRMADAS -->
                <VerticalStackLayout Spacing="12">
                    <Label
                        FontAttributes="Bold"
                        FontSize="18"
                        Text="Confirmadas"
                        TextColor="#1B1B1B" />

                    <CollectionView
                        ItemsSource="{Binding Confirmadas}"
                        SelectionMode="None">
                        <CollectionView.ItemsLayout>
                            <LinearItemsLayout Orientation="Vertical" ItemSpacing="12" />
                        </CollectionView.ItemsLayout>

                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="models:ReceptionTripItem">
                                <Border
                                    Padding="16"
                                    BackgroundColor="White"
                                    StrokeThickness="0"
                                    StrokeShape="RoundRectangle 20">

                                    <VerticalStackLayout Spacing="12">
                                        <Grid ColumnDefinitions="*,Auto">
                                            <VerticalStackLayout Spacing="2">
                                                <Label
                                                    FontAttributes="Bold"
                                                    FontSize="17"
                                                    Text="{Binding Destino}"
                                                    TextColor="#1B1B1B" />
                                                <Label
                                                    FontSize="13"
                                                    Text="{Binding Data}"
                                                    TextColor="#777777" />
                                            </VerticalStackLayout>

                                            <Border
                                                Grid.Column="1"
                                                Padding="10,5"
                                                BackgroundColor="#E8F6EC"
                                                StrokeThickness="0"
                                                StrokeShape="RoundRectangle 12">
                                                <Label
                                                    FontAttributes="Bold"
                                                    FontSize="12"
                                                    Text="{Binding Status}"
                                                    TextColor="#239B56" />
                                            </Border>
                                        </Grid>

                                        <Grid ColumnDefinitions="*,*">
                                            <VerticalStackLayout Spacing="4">
                                                <Label FontSize="12" Text="Horário" TextColor="#2357C6" />
                                                <Label FontSize="14" Text="{Binding Horario}" TextColor="#1B1B1B" />
                                            </VerticalStackLayout>

                                            <VerticalStackLayout Grid.Column="1" Spacing="4">
                                                <Label FontSize="12" Text="Veículo" TextColor="#2357C6" />
                                                <Label FontSize="14" Text="{Binding Veiculo}" TextColor="#1B1B1B" />
                                            </VerticalStackLayout>
                                        </Grid>

                                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                                            <Label
                                                VerticalTextAlignment="Center"
                                                FontSize="13"
                                                Text="{Binding Motorista}"
                                                TextColor="#666666" />

                                            <Button
                                                Grid.Column="1"
                                                BackgroundColor="#F3F5FB"
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:MinhasViagensViewModel}}, Path=AbrirDetalheCommand}"
                                                CommandParameter="{Binding .}"
                                                CornerRadius="14"
                                                HeightRequest="40"
                                                Text="Ver detalhe"
                                                TextColor="#2357C6" />
                                        </Grid>
                                    </VerticalStackLayout>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>

                <!-- EM ANDAMENTO -->
                

                <!-- FINALIZADAS -->
                <VerticalStackLayout Spacing="12">
                    <Label
                        FontAttributes="Bold"
                        FontSize="18"
                        Text="Finalizadas"
                        TextColor="#1B1B1B" />

                    <CollectionView
                        ItemsSource="{Binding Finalizadas}"
                        SelectionMode="None">
                        <CollectionView.ItemsLayout>
                            <LinearItemsLayout Orientation="Vertical" ItemSpacing="12" />
                        </CollectionView.ItemsLayout>

                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="models:ReceptionTripItem">
                                <Border
                                    Padding="16"
                                    BackgroundColor="White"
                                    StrokeThickness="0"
                                    StrokeShape="RoundRectangle 20"
                                    Opacity="0.92">

                                    <VerticalStackLayout Spacing="12">
                                        <Grid ColumnDefinitions="*,Auto">
                                            <VerticalStackLayout Spacing="2">
                                                <Label
                                                    FontAttributes="Bold"
                                                    FontSize="17"
                                                    Text="{Binding Destino}"
                                                    TextColor="#1B1B1B" />
                                                <Label
                                                    FontSize="13"
                                                    Text="{Binding Data}"
                                                    TextColor="#777777" />
                                            </VerticalStackLayout>

                                            <Border
                                                Grid.Column="1"
                                                Padding="10,5"
                                                BackgroundColor="#EEF1F4"
                                                StrokeThickness="0"
                                                StrokeShape="RoundRectangle 12">
                                                <Label
                                                    FontAttributes="Bold"
                                                    FontSize="12"
                                                    Text="{Binding Status}"
                                                    TextColor="#5F6B7A" />
                                            </Border>
                                        </Grid>

                                        <Grid ColumnDefinitions="*,*">
                                            <VerticalStackLayout Spacing="4">
                                                <Label FontSize="12" Text="Horário" TextColor="#2357C6" />
                                                <Label FontSize="14" Text="{Binding Horario}" TextColor="#1B1B1B" />
                                            </VerticalStackLayout>

                                            <VerticalStackLayout Grid.Column="1" Spacing="4">
                                                <Label FontSize="12" Text="Veículo" TextColor="#2357C6" />
                                                <Label FontSize="14" Text="{Binding Veiculo}" TextColor="#1B1B1B" />
                                            </VerticalStackLayout>
                                        </Grid>

                                        <Button
                                            BackgroundColor="#F3F5FB"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:MinhasViagensViewModel}}, Path=AbrirDetalheCommand}"
                                            CommandParameter="{Binding .}"
                                            CornerRadius="14"
                                            HeightRequest="40"
                                            Text="Consultar viagem"
                                            TextColor="#2357C6" />
                                    </VerticalStackLayout>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>