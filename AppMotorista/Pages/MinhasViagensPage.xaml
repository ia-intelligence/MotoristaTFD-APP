<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="AppMotorista.Pages.MinhasViagensPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:models="clr-namespace:AppMotorista.Models"
    xmlns:viewmodels="clr-namespace:AppMotorista.ViewModels"
    x:DataType="viewmodels:MinhasViagensViewModel"
    BackgroundColor="#ECECEC"
    Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto,*">

        <!--  TOPO  -->
        <Grid
            Grid.Row="0"
            Padding="18,24,18,18"
            BackgroundColor="#2357C6"
            ColumnDefinitions="48,*"
            RowDefinitions="Auto,Auto">

            <ImageButton
                BackgroundColor="Transparent"
                Command="{Binding VoltarCommand}"
                HeightRequest="26"
                Source="arrow_left_icon.svg"
                WidthRequest="26" />

            <Label
                Grid.Column="1"
                FontAttributes="Bold"
                FontSize="24"
                HorizontalTextAlignment="Center"
                Text="{Binding TituloPagina}"
                TextColor="White"
                VerticalTextAlignment="Center" />

            <Label
                Grid.Row="1"
                Grid.ColumnSpan="2"
                Margin="0,14,0,0"
                FontSize="13"
                Text="{Binding ResumoPagina}"
                TextColor="#DCE6FF" />
        </Grid>

        <!--  CONTEÚDO  -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="18,18,18,24" Spacing="18">

                <!--  EM ANDAMENTO  -->
                <VerticalStackLayout Spacing="12">
                    <Label
                        FontAttributes="Bold"
                        FontSize="18"
                        Text="Em andamento"
                        TextColor="#1B1B1B" />

                    <CollectionView ItemsSource="{Binding EmAndamento}" SelectionMode="None">
                        <CollectionView.ItemsLayout>
                            <LinearItemsLayout ItemSpacing="14" Orientation="Vertical" />
                        </CollectionView.ItemsLayout>

                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="models:ReceptionTripItem">
                                <Border
                                    Padding="16"
                                    BackgroundColor="White"
                                    StrokeShape="RoundRectangle 20"
                                    StrokeThickness="0">

                                    <VerticalStackLayout Spacing="14">

                                        <Grid ColumnDefinitions="*,Auto">
                                            <VerticalStackLayout Spacing="4">
                                                <Label
                                                    FontSize="13"
                                                    Text="{Binding Data}"
                                                    TextColor="#777777" />

                                                <Label
                                                    FontAttributes="Bold"
                                                    FontSize="24"
                                                    Text="{Binding Horario}"
                                                    TextColor="#2357C6" />
                                            </VerticalStackLayout>

                                            <Border
                                                Grid.Column="1"
                                                Padding="10,5"
                                                BackgroundColor="#E8F1FF"
                                                StrokeShape="RoundRectangle 12"
                                                StrokeThickness="0"
                                                VerticalOptions="Start">
                                                <Label
                                                    FontAttributes="Bold"
                                                    FontSize="12"
                                                    Text="{Binding Status}"
                                                    TextColor="#2357C6" />
                                            </Border>
                                        </Grid>

                                        <VerticalStackLayout Spacing="4">
                                            <Label
                                                FontAttributes="Bold"
                                                FontSize="18"
                                                Text="{Binding Destino}"
                                                TextColor="#1B1B1B" />
                                            <Label
                                                FontSize="13"
                                                Text="{Binding ResumoRota}"
                                                TextColor="#666666" />
                                        </VerticalStackLayout>

                                        <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                                            <VerticalStackLayout Spacing="4">
                                                <Label
                                                    FontSize="12"
                                                    Text="Veículo"
                                                    TextColor="#2357C6" />
                                                <Label
                                                    FontSize="14"
                                                    Text="{Binding Veiculo}"
                                                    TextColor="#1B1B1B" />
                                                <Label
                                                    FontSize="12"
                                                    Text="{Binding VeiculoDetalhe}"
                                                    TextColor="#666666" />
                                            </VerticalStackLayout>

                                            <VerticalStackLayout Grid.Column="1" Spacing="4">
                                                <Label
                                                    FontSize="12"
                                                    Text="Motorista"
                                                    TextColor="#2357C6" />
                                                <Label
                                                    FontSize="14"
                                                    Text="{Binding Motorista}"
                                                    TextColor="#1B1B1B" />
                                            </VerticalStackLayout>
                                        </Grid>

                                        <VerticalStackLayout Spacing="4">
                                            <Label
                                                FontSize="12"
                                                Text="Passageiros"
                                                TextColor="#2357C6" />
                                            <Label
                                                FontSize="14"
                                                Text="{Binding ResumoPassageiros}"
                                                TextColor="#1B1B1B" />
                                        </VerticalStackLayout>

                                        <VerticalStackLayout Spacing="4">
                                            <Label
                                                FontSize="12"
                                                Text="Equipe de apoio"
                                                TextColor="#2357C6" />
                                            <Label
                                                FontSize="14"
                                                Text="{Binding EquipeApoio}"
                                                TextColor="#1B1B1B" />
                                        </VerticalStackLayout>

                                        <Border
                                            Padding="10,6"
                                            BackgroundColor="#FFF4E5"
                                            HorizontalOptions="Start"
                                            IsVisible="{Binding TravaFaturamentoAtiva}"
                                            StrokeShape="RoundRectangle 14"
                                            StrokeThickness="0">
                                            <Label
                                                FontAttributes="Bold"
                                                FontSize="12"
                                                Text="Veículo próprio"
                                                TextColor="#B96A00" />
                                        </Border>

                                        <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                                            <Button
                                                Grid.Column="0"
                                                BackgroundColor="#F3F5FB"
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.AbrirMapaCommand}"
                                                CommandParameter="{Binding .}"
                                                CornerRadius="16"
                                                HeightRequest="46"
                                                Text="Ver mapa"
                                                TextColor="#2357C6" />

                                            <Button
                                                Grid.Column="1"
                                                BackgroundColor="#2357C6"
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.AbrirDetalheCommand}"
                                                CommandParameter="{Binding .}"
                                                CornerRadius="16"
                                                HeightRequest="46"
                                                Text="Ver detalhes"
                                                TextColor="White" />
                                        </Grid>

                                    </VerticalStackLayout>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>

                <!--  CONFIRMADAS  -->
                <VerticalStackLayout Spacing="12">
                    <Label
                        FontAttributes="Bold"
                        FontSize="18"
                        Text="Confirmadas"
                        TextColor="#1B1B1B" />

                    <CollectionView ItemsSource="{Binding Confirmadas}" SelectionMode="None">
                        <CollectionView.ItemsLayout>
                            <LinearItemsLayout ItemSpacing="14" Orientation="Vertical" />
                        </CollectionView.ItemsLayout>

                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="models:ReceptionTripItem">
                                <Border
                                    Padding="16"
                                    BackgroundColor="White"
                                    StrokeShape="RoundRectangle 20"
                                    StrokeThickness="0">

                                    <VerticalStackLayout Spacing="14">

                                        <Grid ColumnDefinitions="*,Auto">
                                            <VerticalStackLayout Spacing="4">
                                                <Label
                                                    FontSize="13"
                                                    Text="{Binding Data}"
                                                    TextColor="#777777" />

                                                <Label
                                                    FontAttributes="Bold"
                                                    FontSize="24"
                                                    Text="{Binding Horario}"
                                                    TextColor="#2357C6" />
                                            </VerticalStackLayout>

                                            <Border
                                                Grid.Column="1"
                                                Padding="10,5"
                                                BackgroundColor="#E8F6EC"
                                                StrokeShape="RoundRectangle 12"
                                                StrokeThickness="0"
                                                VerticalOptions="Start">
                                                <Label
                                                    FontAttributes="Bold"
                                                    FontSize="12"
                                                    Text="{Binding Status}"
                                                    TextColor="#239B56" />
                                            </Border>
                                        </Grid>

                                        <VerticalStackLayout Spacing="4">
                                            <Label
                                                FontAttributes="Bold"
                                                FontSize="18"
                                                Text="{Binding Destino}"
                                                TextColor="#1B1B1B" />
                                            <Label
                                                FontSize="13"
                                                Text="{Binding ResumoRota}"
                                                TextColor="#666666" />
                                        </VerticalStackLayout>

                                        <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                                            <VerticalStackLayout Spacing="4">
                                                <Label
                                                    FontSize="12"
                                                    Text="Veículo"
                                                    TextColor="#2357C6" />
                                                <Label
                                                    FontSize="14"
                                                    Text="{Binding Veiculo}"
                                                    TextColor="#1B1B1B" />
                                                <Label
                                                    FontSize="12"
                                                    Text="{Binding VeiculoDetalhe}"
                                                    TextColor="#666666" />
                                            </VerticalStackLayout>

                                            <VerticalStackLayout Grid.Column="1" Spacing="4">
                                                <Label
                                                    FontSize="12"
                                                    Text="Motorista"
                                                    TextColor="#2357C6" />
                                                <Label
                                                    FontSize="14"
                                                    Text="{Binding Motorista}"
                                                    TextColor="#1B1B1B" />
                                            </VerticalStackLayout>
                                        </Grid>

                                        <VerticalStackLayout Spacing="4">
                                            <Label
                                                FontSize="12"
                                                Text="Passageiros"
                                                TextColor="#2357C6" />
                                            <Label
                                                FontSize="14"
                                                Text="{Binding ResumoPassageiros}"
                                                TextColor="#1B1B1B" />
                                        </VerticalStackLayout>

                                        <VerticalStackLayout Spacing="4">
                                            <Label
                                                FontSize="12"
                                                Text="Equipe de apoio"
                                                TextColor="#2357C6" />
                                            <Label
                                                FontSize="14"
                                                Text="{Binding EquipeApoio}"
                                                TextColor="#1B1B1B" />
                                        </VerticalStackLayout>

                                        <Border
                                            Padding="10,6"
                                            BackgroundColor="#FFF4E5"
                                            HorizontalOptions="Start"
                                            IsVisible="{Binding TravaFaturamentoAtiva}"
                                            StrokeShape="RoundRectangle 14"
                                            StrokeThickness="0">
                                            <Label
                                                FontAttributes="Bold"
                                                FontSize="12"
                                                Text="Veículo próprio"
                                                TextColor="#B96A00" />
                                        </Border>

                                        <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                                            <Button
                                                Grid.Column="0"
                                                BackgroundColor="#F3F5FB"
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.AbrirMapaCommand}"
                                                CommandParameter="{Binding .}"
                                                CornerRadius="16"
                                                HeightRequest="46"
                                                Text="Ver mapa"
                                                TextColor="#2357C6" />

                                            <Button
                                                Grid.Column="1"
                                                BackgroundColor="#2357C6"
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.AbrirDetalheCommand}"
                                                CommandParameter="{Binding .}"
                                                CornerRadius="16"
                                                HeightRequest="46"
                                                Text="Ver detalhes"
                                                TextColor="White" />
                                        </Grid>

                                    </VerticalStackLayout>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>

                <!--  FINALIZADAS  -->
                <VerticalStackLayout Spacing="12">
                    <Label
                        FontAttributes="Bold"
                        FontSize="18"
                        Text="Finalizadas"
                        TextColor="#1B1B1B" />

                    <CollectionView ItemsSource="{Binding Finalizadas}" SelectionMode="None">
                        <CollectionView.ItemsLayout>
                            <LinearItemsLayout ItemSpacing="14" Orientation="Vertical" />
                        </CollectionView.ItemsLayout>

                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="models:ReceptionTripItem">
                                <Border
                                    Padding="16"
                                    BackgroundColor="White"
                                    StrokeShape="RoundRectangle 20"
                                    StrokeThickness="0">

                                    <VerticalStackLayout Spacing="14">

                                        <Grid ColumnDefinitions="*,Auto">
                                            <VerticalStackLayout Spacing="4">
                                                <Label
                                                    FontSize="13"
                                                    Text="{Binding Data}"
                                                    TextColor="#777777" />

                                                <Label
                                                    FontAttributes="Bold"
                                                    FontSize="24"
                                                    Text="{Binding Horario}"
                                                    TextColor="#2357C6" />
                                            </VerticalStackLayout>

                                            <Border
                                                Grid.Column="1"
                                                Padding="10,5"
                                                BackgroundColor="#F0F0F0"
                                                StrokeShape="RoundRectangle 12"
                                                StrokeThickness="0"
                                                VerticalOptions="Start">
                                                <Label
                                                    FontAttributes="Bold"
                                                    FontSize="12"
                                                    Text="{Binding Status}"
                                                    TextColor="#666666" />
                                            </Border>
                                        </Grid>

                                        <VerticalStackLayout Spacing="4">
                                            <Label
                                                FontAttributes="Bold"
                                                FontSize="18"
                                                Text="{Binding Destino}"
                                                TextColor="#1B1B1B" />
                                            <Label
                                                FontSize="13"
                                                Text="{Binding ResumoRota}"
                                                TextColor="#666666" />
                                        </VerticalStackLayout>

                                        <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                                            <VerticalStackLayout Spacing="4">
                                                <Label
                                                    FontSize="12"
                                                    Text="Veículo"
                                                    TextColor="#2357C6" />
                                                <Label
                                                    FontSize="14"
                                                    Text="{Binding Veiculo}"
                                                    TextColor="#1B1B1B" />
                                                <Label
                                                    FontSize="12"
                                                    Text="{Binding VeiculoDetalhe}"
                                                    TextColor="#666666" />
                                            </VerticalStackLayout>

                                            <VerticalStackLayout Grid.Column="1" Spacing="4">
                                                <Label
                                                    FontSize="12"
                                                    Text="Motorista"
                                                    TextColor="#2357C6" />
                                                <Label
                                                    FontSize="14"
                                                    Text="{Binding Motorista}"
                                                    TextColor="#1B1B1B" />
                                            </VerticalStackLayout>
                                        </Grid>

                                        <VerticalStackLayout Spacing="4">
                                            <Label
                                                FontSize="12"
                                                Text="Passageiros"
                                                TextColor="#2357C6" />
                                            <Label
                                                FontSize="14"
                                                Text="{Binding ResumoPassageiros}"
                                                TextColor="#1B1B1B" />
                                        </VerticalStackLayout>

                                        <VerticalStackLayout Spacing="4">
                                            <Label
                                                FontSize="12"
                                                Text="Equipe de apoio"
                                                TextColor="#2357C6" />
                                            <Label
                                                FontSize="14"
                                                Text="{Binding EquipeApoio}"
                                                TextColor="#1B1B1B" />
                                        </VerticalStackLayout>

                                        <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                                            <Button
                                                Grid.Column="0"
                                                BackgroundColor="#F3F5FB"
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.AbrirMapaCommand}"
                                                CommandParameter="{Binding .}"
                                                CornerRadius="16"
                                                HeightRequest="46"
                                                Text="Ver mapa"
                                                TextColor="#2357C6" />

                                            <Button
                                                Grid.Column="1"
                                                BackgroundColor="#2357C6"
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.AbrirDetalheCommand}"
                                                CommandParameter="{Binding .}"
                                                CornerRadius="16"
                                                HeightRequest="46"
                                                Text="Ver detalhes"
                                                TextColor="White" />
                                        </Grid>

                                    </VerticalStackLayout>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>