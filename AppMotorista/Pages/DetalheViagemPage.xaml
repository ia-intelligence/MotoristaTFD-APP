<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="AppMotorista.Pages.DetalheViagemPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:dx="http://schemas.devexpress.com/maui"
    xmlns:models="clr-namespace:AppMotorista.Models"
    xmlns:viewmodels="clr-namespace:AppMotorista.ViewModels"
    x:DataType="viewmodels:DetalheViagemViewModel"
    BackgroundColor="#F3F4F6"
    Shell.NavBarIsVisible="False">

    <Grid>

        <!--  CONTEÚDO PRINCIPAL  -->
        <Grid RowDefinitions="Auto,*,Auto">

            <!--  TOPO AZUL  -->
            <Grid
                Grid.Row="0"
                Padding="8,0,8,0"
                BackgroundColor="#2357C6"
                ColumnDefinitions="40,*,40"
                HeightRequest="46">

                <ImageButton
                    Grid.Column="0"
                    Padding="4"
                    BackgroundColor="Transparent"
                    Command="{Binding AlternarMenuCommand}"
                    HeightRequest="24"
                    HorizontalOptions="Center"
                    Source="menuhamburguer_icon.svg"
                    VerticalOptions="Center"
                    WidthRequest="24" />

                <Label
                    Grid.Column="1"
                    FontAttributes="Bold"
                    FontSize="13"
                    HorizontalTextAlignment="Start"
                    Text="TFD Motorista"
                    TextColor="White"
                    VerticalTextAlignment="Center" />

                <ImageButton
                    Grid.Column="2"
                    Padding="4"
                    BackgroundColor="Transparent"
                    Command="{Binding AbrirQrCodeCommand}"
                    HeightRequest="24"
                    HorizontalOptions="Center"
                    Source="qrcode_icon.svg"
                    VerticalOptions="Center"
                    WidthRequest="24" />
            </Grid>

            <!--  CONTEÚDO  -->
            <ScrollView Grid.Row="1">
                <VerticalStackLayout Padding="10,10,10,20" Spacing="10">

                    <!--  CARD PRINCIPAL  -->
                    <Border
                        Padding="12"
                        BackgroundColor="White"
                        StrokeThickness="0">

                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="16" />
                        </Border.StrokeShape>

                        <VerticalStackLayout Spacing="8">

                            <!--  STATUS + HORÁRIO  -->
                            <Grid ColumnDefinitions="Auto,*,Auto">

                                <Border
                                    Grid.Column="0"
                                    Padding="8,3"
                                    BackgroundColor="#EEF3FF"
                                    HorizontalOptions="Start"
                                    StrokeThickness="0">

                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="8" />
                                    </Border.StrokeShape>

                                    <Label
                                        FontAttributes="Bold"
                                        FontSize="8"
                                        Text="{Binding Status}"
                                        TextColor="#2357C6" />
                                </Border>

                                <Label
                                    Grid.Column="2"
                                    FontAttributes="Bold"
                                    FontSize="11"
                                    Text="{Binding Horario}"
                                    TextColor="#2357C6"
                                    VerticalTextAlignment="Center" />
                            </Grid>

                            <!--  DESTINO  -->
                            <Label
                                FontAttributes="Bold"
                                FontSize="13"
                                LineBreakMode="TailTruncation"
                                MaxLines="2"
                                Text="{Binding Destino}"
                                TextColor="#111827" />

                            <!--  LOCAL  -->
                            <HorizontalStackLayout Spacing="6">
                                <Label
                                    FontSize="11"
                                    Text="📍"
                                    VerticalTextAlignment="Center" />
                                <Label
                                    FontSize="10"
                                    Text="{Binding LocalResumo}"
                                    TextColor="#8A93A3"
                                    VerticalTextAlignment="Center" />
                            </HorizontalStackLayout>
                        </VerticalStackLayout>
                    </Border>

                    <!--  ROTEIRO DA VIAGEM  -->
                    <Border
                        Padding="12"
                        BackgroundColor="White"
                        StrokeThickness="0">

                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="16" />
                        </Border.StrokeShape>

                        <VerticalStackLayout Spacing="10">

                            <Label
                                FontAttributes="Bold"
                                FontSize="12"
                                Text="Roteiro da Viagem"
                                TextColor="#374151" />

                            <Grid
                                ColumnDefinitions="18,*"
                                ColumnSpacing="8"
                                RowDefinitions="Auto,Auto,Auto"
                                RowSpacing="10">

                                <!--  LINHA 1  -->
                                <Border
                                    Grid.Row="0"
                                    Grid.Column="0"
                                    BackgroundColor="#2357C6"
                                    HeightRequest="8"
                                    HorizontalOptions="Center"
                                    StrokeThickness="0"
                                    VerticalOptions="Center"
                                    WidthRequest="8">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="4" />
                                    </Border.StrokeShape>
                                </Border>

                                <VerticalStackLayout
                                    Grid.Row="0"
                                    Grid.Column="1"
                                    Spacing="0">
                                    <Label
                                        FontSize="8"
                                        Text="Origem"
                                        TextColor="#8A93A3" />
                                    <Label
                                        FontSize="10"
                                        Text="{Binding Origem}"
                                        TextColor="#111827" />
                                </VerticalStackLayout>

                                <!--  LINHA VERTICAL 1  -->
                                <BoxView
                                    Grid.Row="1"
                                    Grid.Column="0"
                                    HeightRequest="18"
                                    HorizontalOptions="Center"
                                    VerticalOptions="Start"
                                    WidthRequest="1"
                                    Color="#D1D5DB" />

                                <!--  LINHA 2  -->
                                <Border
                                    Grid.Row="1"
                                    Grid.Column="0"
                                    Margin="0,10,0,0"
                                    BackgroundColor="#6F8EF6"
                                    HeightRequest="8"
                                    HorizontalOptions="Center"
                                    StrokeThickness="0"
                                    VerticalOptions="Start"
                                    WidthRequest="8">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="4" />
                                    </Border.StrokeShape>
                                </Border>

                                <VerticalStackLayout
                                    Grid.Row="1"
                                    Grid.Column="1"
                                    Spacing="0">
                                    <Label
                                        FontSize="8"
                                        Text="Parada"
                                        TextColor="#8A93A3" />
                                    <Label
                                        FontSize="10"
                                        Text="{Binding ParadaIntermediaria}"
                                        TextColor="#111827" />
                                </VerticalStackLayout>

                                <!--  LINHA 3  -->
                                <Border
                                    Grid.Row="2"
                                    Grid.Column="0"
                                    BackgroundColor="#9CA3AF"
                                    HeightRequest="8"
                                    HorizontalOptions="Center"
                                    StrokeThickness="0"
                                    VerticalOptions="Center"
                                    WidthRequest="8">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="4" />
                                    </Border.StrokeShape>
                                </Border>

                                <VerticalStackLayout
                                    Grid.Row="2"
                                    Grid.Column="1"
                                    Spacing="0">
                                    <Label
                                        FontSize="8"
                                        Text="Destino"
                                        TextColor="#8A93A3" />
                                    <Label
                                        FontSize="10"
                                        Text="{Binding DestinoCurto}"
                                        TextColor="#111827" />
                                </VerticalStackLayout>
                            </Grid>

                        </VerticalStackLayout>
                    </Border>

                    <!--  VEÍCULO  -->
                    <Border
                        Padding="12"
                        BackgroundColor="White"
                        StrokeThickness="0">

                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="16" />
                        </Border.StrokeShape>

                        <Grid ColumnDefinitions="28,*,Auto" ColumnSpacing="8">

                            <Border
                                BackgroundColor="#EEF3FF"
                                HeightRequest="26"
                                StrokeThickness="0"
                                VerticalOptions="Center"
                                WidthRequest="26">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="8" />
                                </Border.StrokeShape>

                                <Image
                                    HeightRequest="14"
                                    HorizontalOptions="Center"
                                    Source="fleet_icon.svg"
                                    VerticalOptions="Center"
                                    WidthRequest="14" />
                            </Border>

                            <VerticalStackLayout Grid.Column="1" Spacing="0">
                                <Label
                                    FontSize="8"
                                    Text="Veículo"
                                    TextColor="#8A93A3" />
                                <Label
                                    FontAttributes="Bold"
                                    FontSize="10"
                                    Text="{Binding ModeloVeiculo}"
                                    TextColor="#111827" />
                            </VerticalStackLayout>
                        </Grid>
                    </Border>

                    <!--  OCUPAÇÃO  -->
                    <Border
                        Padding="12"
                        BackgroundColor="White"
                        StrokeThickness="0">

                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="16" />
                        </Border.StrokeShape>

                        <VerticalStackLayout Spacing="6">

                            <Grid ColumnDefinitions="28,*,Auto" ColumnSpacing="8">

                                <Border
                                    BackgroundColor="#EEF3FF"
                                    HeightRequest="26"
                                    StrokeThickness="0"
                                    VerticalOptions="Center"
                                    WidthRequest="26">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="8" />
                                    </Border.StrokeShape>

                                    <Label
                                        FontSize="11"
                                        HorizontalTextAlignment="Center"
                                        Text="👥"
                                        VerticalTextAlignment="Center" />
                                </Border>

                                <Label
                                    Grid.Column="1"
                                    FontAttributes="Bold"
                                    FontSize="10"
                                    Text="Ocupação"
                                    TextColor="#111827"
                                    VerticalTextAlignment="Center" />

                                <Label
                                    Grid.Column="2"
                                    FontAttributes="Bold"
                                    FontSize="10"
                                    Text="{Binding OcupacaoTexto}"
                                    TextColor="#6B7280"
                                    VerticalTextAlignment="Center" />
                            </Grid>

                            <ProgressBar
                                BackgroundColor="#E5E7EB"
                                HeightRequest="4"
                                Progress="{Binding OcupacaoPercentual}"
                                ProgressColor="#2357C6" />
                        </VerticalStackLayout>
                    </Border>

                    <!--  CENTRO DE APOIO  -->
                    <Border
                        Padding="12"
                        BackgroundColor="White"
                        StrokeThickness="0">

                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="16" />
                        </Border.StrokeShape>

                        <Grid ColumnDefinitions="42,*,36" ColumnSpacing="8">

                            <Border
                                BackgroundColor="#DDF6EC"
                                HeightRequest="38"
                                StrokeThickness="0"
                                VerticalOptions="Center"
                                WidthRequest="38">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="12" />
                                </Border.StrokeShape>

                                <Label
                                    FontSize="16"
                                    HorizontalTextAlignment="Center"
                                    Text="👩‍⚕️"
                                    VerticalTextAlignment="Center" />
                            </Border>

                            <VerticalStackLayout Grid.Column="1" Spacing="0">
                                <Label
                                    FontSize="8"
                                    Text="Centro de Apoio"
                                    TextColor="#8A93A3" />
                                <Label
                                    FontAttributes="Bold"
                                    FontSize="10"
                                    Text="{Binding ContatoApoio}"
                                    TextColor="#111827" />
                            </VerticalStackLayout>

                            <Border
                                Grid.Column="2"
                                BackgroundColor="#F5F7FB"
                                HeightRequest="32"
                                StrokeThickness="0"
                                VerticalOptions="Center"
                                WidthRequest="32">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="16" />
                                </Border.StrokeShape>

                                <Label
                                    FontSize="12"
                                    HorizontalTextAlignment="Center"
                                    Text="📞"
                                    VerticalTextAlignment="Center" />
                            </Border>
                        </Grid>
                    </Border>

                    <!--  MAPA  -->
                    <Border
                        Padding="10"
                        BackgroundColor="#7FD3CC"
                        HeightRequest="120"
                        StrokeThickness="0">

                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="16" />
                        </Border.StrokeShape>

                        <Grid>

                            <Label
                                FontAttributes="Bold"
                                FontSize="12"
                                HorizontalOptions="Center"
                                Text="Mapa da rota"
                                TextColor="#0F5F59"
                                VerticalOptions="Center" />

                            <dx:DXButton
                                Margin="0,0,0,6"
                                ButtonType="Outlined"
                                Command="{Binding AbrirMapaCommand}"
                                Content="Ver mapa"
                                CornerRadius="10"
                                HeightRequest="34"
                                HorizontalOptions="Center"
                                VerticalOptions="End"
                                WidthRequest="110" />
                        </Grid>
                    </Border>

                    <!--  BOTÕES  -->
                    <VerticalStackLayout Spacing="8">

                        <dx:DXButton
                            ButtonType="Accent"
                            Command="{Binding IniciarViagemCommand}"
                            Content="Iniciar viagem"
                            CornerRadius="10"
                            HeightRequest="42" />

                        <dx:DXButton
                            ButtonType="Accent"
                            Command="{Binding AbrirEmbarqueCommand}"
                            Content="Realizar embarque"
                            CornerRadius="10"
                            HeightRequest="42" />

                        <Grid ColumnDefinitions="*,*" ColumnSpacing="8">

                            <dx:DXButton
                                Grid.Column="0"
                                ButtonType="Outlined"
                                Command="{Binding ConfirmarEmbarqueCommand}"
                                Content="Confirmar embarque"
                                CornerRadius="10"
                                HeightRequest="40" />

                            <dx:DXButton
                                Grid.Column="1"
                                ButtonType="Outlined"
                                Command="{Binding RegistrarOcorrenciaCommand}"
                                Content="Registrar ocorrência"
                                CornerRadius="10"
                                HeightRequest="40" />
                        </Grid>

                    </VerticalStackLayout>

                </VerticalStackLayout>
            </ScrollView>

            <!--  BOTTOM NAV  -->
            <Border
                Grid.Row="2"
                Padding="8,8,8,10"
                BackgroundColor="White"
                Stroke="#E5E7EB"
                StrokeThickness="1">

                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="18,18,0,0" />
                </Border.StrokeShape>

                <Grid ColumnDefinitions="*,*,*,*">

                    <!--  INÍCIO  -->
                    <Grid Grid.Column="0" HeightRequest="58">
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding IrInicioCommand}" />
                        </Grid.GestureRecognizers>

                        <VerticalStackLayout
                            HorizontalOptions="Center"
                            Spacing="3"
                            VerticalOptions="Center">

                            <Image
                                HeightRequest="20"
                                Source="menunavbar_home_inativo_icon.svg"
                                WidthRequest="20" />

                            <Label
                                FontSize="10"
                                HorizontalTextAlignment="Center"
                                Text="Início"
                                TextColor="#6B7280" />
                        </VerticalStackLayout>
                    </Grid>

                    <!--  VIAGENS  -->
                    <Border
                        Grid.Column="1"
                        BackgroundColor="#EEF3FF"
                        HeightRequest="58"
                        HorizontalOptions="Center"
                        StrokeThickness="0"
                        VerticalOptions="Center"
                        WidthRequest="70">

                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="12" />
                        </Border.StrokeShape>

                        <Grid>
                            <Grid.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding IrViagensCommand}" />
                            </Grid.GestureRecognizers>

                            <VerticalStackLayout
                                HorizontalOptions="Center"
                                Spacing="3"
                                VerticalOptions="Center">

                                <Image
                                    HeightRequest="20"
                                    Source="menunavbar_viagens_ativo_icon.svg"
                                    WidthRequest="20" />

                                <Label
                                    FontAttributes="Bold"
                                    FontSize="10"
                                    HorizontalTextAlignment="Center"
                                    Text="Viagens"
                                    TextColor="#2357C6" />
                            </VerticalStackLayout>
                        </Grid>
                    </Border>

                    <!--  ALERTAS  -->
                    <Grid Grid.Column="2" HeightRequest="58">
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding IrAlertasCommand}" />
                        </Grid.GestureRecognizers>

                        <VerticalStackLayout
                            HorizontalOptions="Center"
                            Spacing="3"
                            VerticalOptions="Center">

                            <Image
                                HeightRequest="20"
                                Source="menunavbar_alertas_inativo_icon.svg"
                                WidthRequest="20" />

                            <Label
                                FontSize="10"
                                HorizontalTextAlignment="Center"
                                Text="Alertas"
                                TextColor="#6B7280" />
                        </VerticalStackLayout>
                    </Grid>

                    <!--  PERFIL  -->
                    <Grid Grid.Column="3" HeightRequest="58">
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding IrPerfilCommand}" />
                        </Grid.GestureRecognizers>

                        <VerticalStackLayout
                            HorizontalOptions="Center"
                            Spacing="3"
                            VerticalOptions="Center">

                            <Image
                                HeightRequest="20"
                                Source="menunavbar_perfil_inativo_icon.svg"
                                WidthRequest="20" />

                            <Label
                                FontSize="10"
                                HorizontalTextAlignment="Center"
                                Text="Perfil"
                                TextColor="#6B7280" />
                        </VerticalStackLayout>
                    </Grid>

                </Grid>
            </Border>

        </Grid>

        <!--  OVERLAY  -->
        <Grid BackgroundColor="#66000000" IsVisible="{Binding MenuAberto}">
            <Grid.GestureRecognizers>
                <TapGestureRecognizer Command="{Binding FecharMenuCommand}" />
            </Grid.GestureRecognizers>
        </Grid>

        <!--  MENU LATERAL  -->
        <Grid
            BackgroundColor="White"
            HorizontalOptions="Start"
            IsVisible="{Binding MenuAberto}"
            WidthRequest="272">

            <Grid RowDefinitions="Auto,*,Auto">

                <!--  TOPO MENU  -->
                <VerticalStackLayout
                    Grid.Row="0"
                    Padding="18,28,18,20"
                    Spacing="10">

                    <Border
                        BackgroundColor="#EAF1FF"
                        HeightRequest="52"
                        StrokeThickness="0"
                        WidthRequest="52">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="26" />
                        </Border.StrokeShape>

                        <Label
                            FontAttributes="Bold"
                            FontSize="18"
                            HorizontalTextAlignment="Center"
                            Text="JS"
                            TextColor="#2357C6"
                            VerticalTextAlignment="Center" />
                    </Border>

                    <VerticalStackLayout Spacing="2">
                        <Label
                            FontAttributes="Bold"
                            FontSize="13"
                            Text="{Binding NomeMotorista}"
                            TextColor="#111827" />

                        <Label
                            FontSize="10"
                            Text="{Binding IdMotorista}"
                            TextColor="#6B7280" />

                        <Border
                            Padding="6,2"
                            BackgroundColor="#EEF3FF"
                            HorizontalOptions="Start"
                            StrokeThickness="0">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="5" />
                            </Border.StrokeShape>

                            <Label
                                FontAttributes="Bold"
                                FontSize="8"
                                Text="MOTORISTA TFD"
                                TextColor="#2357C6" />
                        </Border>
                    </VerticalStackLayout>
                </VerticalStackLayout>

                <!--  ITENS MENU  -->
                <CollectionView
                    Grid.Row="1"
                    ItemsSource="{Binding ItensMenu}"
                    SelectionMode="None">

                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:SideMenuItem">
                            <Grid Padding="12,2">

                                <Border
                                    Padding="12,10"
                                    BackgroundColor="{Binding CorFundo}"
                                    StrokeThickness="0">

                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="4" />
                                    </Border.StrokeShape>

                                    <Grid ColumnDefinitions="22,*" ColumnSpacing="10">
                                        <Grid.GestureRecognizers>
                                            <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.AbrirItemMenuCommand}" CommandParameter="{Binding .}" />
                                        </Grid.GestureRecognizers>

                                        <Image
                                            Grid.Column="0"
                                            HeightRequest="16"
                                            Source="{Binding Icone}"
                                            VerticalOptions="Center"
                                            WidthRequest="16" />

                                        <Label
                                            Grid.Column="1"
                                            FontSize="11"
                                            Text="{Binding Titulo}"
                                            TextColor="{Binding CorTexto}"
                                            VerticalTextAlignment="Center" />
                                    </Grid>
                                </Border>
                            </Grid>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <!--  SAIR  -->
                <VerticalStackLayout
                    Grid.Row="2"
                    Padding="18,0,18,28"
                    Spacing="16">

                    <BoxView HeightRequest="1" Color="#F0F0F0" />

                    <Grid ColumnDefinitions="24,*" ColumnSpacing="8">
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding SairCommand}" />
                        </Grid.GestureRecognizers>

                        <Image
                            Grid.Column="0"
                            HeightRequest="16"
                            Source="power_icon.svg"
                            VerticalOptions="Center"
                            WidthRequest="16" />

                        <Label
                            Grid.Column="1"
                            FontSize="11"
                            Text="Sair"
                            TextColor="#E53935"
                            VerticalTextAlignment="Center" />
                    </Grid>
                </VerticalStackLayout>

            </Grid>
        </Grid>

    </Grid>
</ContentPage>